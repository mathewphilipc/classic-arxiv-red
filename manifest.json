{
  "manifest_version": 3,
  "name": "Classic arXiv Red",
  "short_name": "arXiv Red",
  "version": "0.1.0",
  "description": "Restores arXiv's classic crimson header.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://arxiv.org/*",
        "https://*.arxiv.org/*"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_start"
    }
  ]
}
